# Copy this file to .env and fill in your key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# ACD-Bot OpenAI spend guard
ACD_BOT_MONTHLY_BUDGET_USD=5
ACD_BOT_USAGE_LEDGER_PATH=/data/acd-bot-openai-usage.json
ACD_BOT_REQUEST_COST_RESERVE_USD=0.02
ACD_BOT_PRICE_INPUT_USD_PER_1M=5
ACD_BOT_PRICE_CACHED_INPUT_USD_PER_1M=5
ACD_BOT_PRICE_OUTPUT_USD_PER_1M=20
